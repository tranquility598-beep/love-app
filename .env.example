# ============================================
# Love App - Environment Variables Template
# ============================================
# 
# ⚠️ ВАЖНО: НЕ КОММИТЬТЕ ФАЙЛ .env В GIT!
# Этот файл - только шаблон для настройки
#
# Инструкция:
# 1. Скопируйте этот файл как .env
# 2. Заполните все значения своими данными
# 3. Убедитесь что .env в .gitignore
# ============================================

# MongoDB Configuration
# Локально: mongodb://localhost:27017/love-app
# Production (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/love-app
MONGODB_URI=mongodb://localhost:27017/love-app

# Создатель / админ-панель (сокет founder:*): email или список user id через запятую
# FOUNDER_EMAIL=you@example.com
# FOUNDER_IDS=69b26a1f2ab0c77d91a105d4

# JWT Secret (ОБЯЗАТЕЛЬНО СМЕНИТЕ!)
# Сгенерируйте случайную строку: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-CHANGE-THIS-TO-RANDOM-STRING

# Server Configuration
PORT=5555
MAX_FILE_SIZE=52428800
CLIENT_URL=http://localhost:3000

# CORS Allowed Origins (comma-separated)
# Добавьте свои домены через запятую
ALLOWED_ORIGINS=http://localhost:5555,http://26.237.63.189:5555

# Google OAuth Credentials (Development)
# Получите на: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:5555/api/auth/google/callback

# Google OAuth Credentials (Production)
# Для Render/Heroku добавьте production callback URL
PROD_GOOGLE_CALLBACK_URL=https://your-domain.onrender.com/api/auth/google/callback

# Email Configuration (Gmail OTP)
# Используйте App Password, не обычный пароль!
# Инструкция: https://support.google.com/accounts/answer/185833
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=your-gmail-app-password-here

# ============================================
# Production Deployment (Render/Heroku)
# ============================================
# 
# Для production НЕ используйте .env файл!
# Добавьте переменные через Dashboard:
#
# Render: Dashboard → Environment → Add Environment Variable
# Heroku: Settings → Config Vars → Reveal Config Vars
#
# Рекомендации для production:
# - Используйте разные JWT_SECRET для dev и prod
# - Используйте MongoDB Atlas вместо локальной БД
# - Создайте отдельные Google OAuth credentials для prod
# - Используйте HTTPS для всех callback URLs
# ============================================
